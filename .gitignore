# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# saved agent runs (Phase 1: keep out of git; demo.json is an opt-in exception)
/.runs/
!/.runs/demo.json

# Local agent state (run records, autoresearch ledger, version counter) —
# never commit; regenerated per machine. Historical snapshot is preserved
# on disk but everything writes to Convex now.
/.data/

# Convex auto-generated types/runtime. `pnpm convex:dev` regenerates these
# on each developer's machine.
/convex/_generated/

# Per-session stdio log files from spawned autoresearch child processes.
# Tailable from the session detail page; never commit.
/.mrkrabs-logs/
